# Gemini API Key (obtained from Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated allowed CORS origins (no brackets/quotes).
# Add your deployed frontend URL in production (e.g. https://yourfrontend.run.app)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage backend: "local" (default) or "gcs"
STORAGE_BACKEND=local

# GCS Bucket name (required if STORAGE_BACKEND is "gcs")
GCS_BUCKET_NAME=dmbhawkeye
